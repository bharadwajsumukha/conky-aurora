bars=24                       		 -- nr of bars must be set in cava-config!!! (needs a restart of conky)
max=1000                      		 -- max value of bars
cap="b "
x=60                         		 -- First bar vertical position
y=70                         		 -- Bars horizontal positions
barspaces=9                   		 -- Spaces between bars
angle_bar=0                 		 -- Set angle of bar (make it circular)
radius=6                      		 -- Radius of the circle
fg_colour={0x00bbff,.8}        		 -- Foreground color of activated blocks
bg_colour={0x222222,0.9}        		 -- Background color of deactived blocks
alarm_colour={0xff8700,1}     		 -- Gradient color to the max
smooth=true                   		 -- Smooth bars
blockspaces=3                 		 -- Space between the blocks
blocks=7                     		 -- Nr of blocks per bar
height=4                      		 -- Height of a block
width=3.5                      		 -- Width of a block
angle=24                       		 -- Angle of all bars
skew_x=24                      		 -- Skew bars (can be negative number)
skew_y=-180                      		 -- Skew blocks (can be negative number)
reflection="b"                		 -- Position of the reflection
reflection_alpha=0            		 -- Alpha blend of reflection (0 to 1)
reflection_length=0           		 -- Length of reflection (0 to 1)
reflection_scale=1            		 -- Scale/stretch of reflection (can only be higher then 0)
