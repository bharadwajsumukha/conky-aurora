#!/bin/bash
# show-lyric — renders the 5-line context window of synced lyrics to lyrics.out.
# Called by conky every 0.5s via ${execp}. Optimised to minimise forks/subshells.
# v1 01 2026-03-09 @rew62

BASEDIR="$(cd "$(dirname "$0")" && pwd)"
TMP="/dev/shm/conky-lyrics"
txtfile="$TMP/lyrics.txt"
outfile="$TMP/lyrics.out"
cfgfile="$BASEDIR/show-lyric.ini"
cachefile="$TMP/lyrics.parsed"   # Pre-parsed lyric cache (rebuilt on song change)
songfile="$TMP/lyrics.chk"       # Current song fingerprint

source "$cfgfile"

# ── Player check (one playerctl call, not two) ─────────────────────────────
[ -f "$TMP/player.running" ] || { > "$outfile"; exit; }
player_name=$(< "$TMP/player.running")
[ -z "$player_name" ] && { > "$outfile"; exit; }

# Two separate playerctl calls — status and position are top-level properties,
# not metadata fields, so they cannot be fetched via metadata --format.
status=$(playerctl -p "$player_name" status 2>/dev/null)

if [ "$status" != "Playing" ]; then
    > "$outfile"
    exit
fi

# position returns seconds as a float (e.g. "74.502000"), NOT microseconds
position_sec=$(playerctl -p "$player_name" position 2>/dev/null)
if [ -z "$position_sec" ]; then
    > "$outfile"
    exit
fi

# Apply timing offset in seconds
if [ "${timing:-0}" != "0" ]; then
    position_sec=$(awk "BEGIN{printf \"%.3f\", $position_sec + $timing}")
fi

# ── Lyrics file check ──────────────────────────────────────────────────────
[ -f "$txtfile" ] || { > "$outfile"; exit; }

# ── Parse lyrics into cache (only when song changes) ──────────────────────
# The cache file holds tab-separated "time\ttext" lines, pre-sorted by time.
current_song=""
[ -f "$songfile" ] && current_song=$(< "$songfile")

if [ ! -f "$cachefile" ] || \
   [ "$txtfile" -nt "$cachefile" ]; then
    # Rebuild parsed cache using awk (single process, no bash loop)
    awk '
        NR <= 4 { next }  # skip Artist / Title / Album / blank header lines
        /^\[[0-9]+:[0-9]/ {
            # arr[1]=min, arr[2]=sec, arr[3]=frac (with leading dot e.g. ".502"), arr[4]=text
            if (match($0, /^\[([0-9]+):([0-9]+)(\.[0-9]+)?\](.*)/, arr)) {
                frac = (arr[3] == "") ? 0 : substr(arr[3], 2) + 0  # strip leading dot
                t = arr[1]*60 + arr[2] + frac/1000
                printf "%.3f\t%s\n", t, arr[4]
            }
        }
    ' "$txtfile" > "$cachefile"
fi

# ── Find current lyric index with awk (no bc loop) ────────────────────────
# awk reads the cache once and emits the matching index
current_idx=$(awk -F'\t' -v pos="$position_sec" '
    { times[NR]=$1; lines[NR]=$2 }
    END {
        idx=0
        for(i=1;i<=NR;i++){
            if(pos >= times[i]+0) idx=i
            else break
        }
        print idx-1   # 0-based
    }
' "$cachefile")

# ── Read lines array from cache ───────────────────────────────────────────
mapfile -t lyr_lines < <(awk -F'\t' '{print $2}' "$cachefile")
total=${#lyr_lines[@]}

# ── Render 5-line window ──────────────────────────────────────────────────
{
    for offset in -2 -1 0 1 2; do
        idx=$(( current_idx + offset ))
        if [ $idx -lt 0 ] || [ $idx -ge $total ]; then
            echo ""
            continue
        fi
        line_text="${lyr_lines[$idx]}"
        case $offset in
            -2|2) printf '%s%s${color %s}%s\n' "$offset1" "$font1" "$col1" "$line_text" ;;
            -1|1) printf '%s%s${color %s}%s\n' "$offset2" "$font2" "$col2" "$line_text" ;;
             0)   printf '%s%s${color %s}%s\n' "$offset3" "$font3" "$col3" "$line_text" ;;
        esac
    done
} > "$outfile"
