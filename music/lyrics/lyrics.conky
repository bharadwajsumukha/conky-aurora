conky.config = {
	background = false,
	alignment = 'bottom_middle',
	gap_x = 0,
	gap_y = 410,
	use_xft = true,
	font = 'Bitstream Charter Regular:size=8',
	xftalpha = 1,
	update_interval = 0.5,
	total_run_times = 0,
	own_window = true,
	own_window_transparent = true,
	own_window_argb_visual = true,
	own_window_type = 'normal',
	own_window_hints = 'undecorated,below,skip_taskbar,skip_pager',
	double_buffer = true,
	minimum_width = 340, minimum_height = 80,
	maximum_width = 340,
	text_buffer_size = 2048,
	draw_shades = false,
	draw_outline = false,
	draw_borders = false,
	draw_graph_borders = false,
	default_color = '#ffffff',
	default_shade_color = '#333333',
	default_outline_color = 'black',
	no_buffers = true,
	uppercase = false,
	cpu_avg_samples = 2,
	override_utf8_locale = true,
	imlib_cache_flush_interval = 60,
	imlib_cache_size = 10000,
	stippled_borders = 5,
	lua_load = './settings.lua scripts/loadall.lua',
	lua_draw_hook_pre = 'main',
	lua_startup_hook = 'vars',
};

-- NOTE: active-player.sh is no longer polled via texeci.
-- Launch it once as a background daemon before starting conky:
--   ./active-player.sh &
-- Or add to your session autostart / conky wrapper script.
-- This eliminates the texeci fork overhead and the startup race.
--
-- show-lyric still runs every 0.5s to update the displayed line,
-- but is now much cheaper (no bc loop, no extra playerctl calls,
-- uses /dev/shm for all file I/O).

conky.text = [[
${execp ./show-lyric}\
${execp cat /dev/shm/conky-lyrics/lyrics.out}
]];
